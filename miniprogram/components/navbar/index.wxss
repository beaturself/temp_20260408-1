.navbar {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  background: linear-gradient(180deg, var(--bg-gradient-start) 0%, var(--bg-gradient-mid) 100%);
}

.navbar-inner {
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  padding: 0 120rpx;
}

.navbar-left {
  position: absolute;
  left: 16rpx;
  top: 0;
  bottom: 0;
  display: flex;
  align-items: center;
  gap: 4rpx;
}

.navbar-back {
  display: flex;
  align-items: center;
  padding: 0 12rpx;
}

.back-arrow {
  font-size: 48rpx;
  color: var(--text-primary);
  font-weight: 300;
  line-height: 1;
}

.navbar-title {
  font-size: 34rpx;
  font-weight: 600;
  color: var(--text-primary);
  text-align: center;
  overflow: hidden;
  white-space: nowrap;
  text-overflow: ellipsis;
}
