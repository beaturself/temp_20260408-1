/* components/chat-history/index.wxss - 对话历史面板样式 */
.history-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.35);
  z-index: 200;
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.3s ease;
}

.history-mask.show {
  opacity: 1;
  pointer-events: auto;
}

.history-panel {
  position: fixed;
  top: 0;
  left: 0;
  bottom: 0;
  width: 560rpx;
  z-index: 201;
  background: linear-gradient(180deg, var(--bg-gradient-start) 0%, var(--bg-gradient-end) 100%);
  transform: translateX(-100%);
  transition: transform 0.3s ease;
  display: flex;
  flex-direction: column;
  box-shadow: 8rpx 0 32rpx rgba(0, 0, 0, 0.1);
}

.history-panel.show {
  transform: translateX(0);
}

.history-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 32rpx;
  padding-top: calc(env(safe-area-inset-top, 40px) + 80rpx);
  border-bottom: 1rpx solid var(--border-light);
}

.history-title {
  font-size: 34rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.history-new-btn {
  font-size: 26rpx;
  color: var(--color-primary);
  padding: 12rpx 24rpx;
  border-radius: var(--radius-full);
  background: rgba(255, 140, 66, 0.1);
}

.history-new-btn:active {
  background: rgba(255, 140, 66, 0.2);
}

.history-list {
  flex: 1;
  padding: var(--spacing-sm);
}

.history-item {
  display: flex;
  align-items: center;
  padding: 28rpx 24rpx;
  border-radius: var(--radius-md);
  margin-bottom: 8rpx;
  transition: background 0.2s;
}

.history-item:active {
  background: rgba(255, 140, 66, 0.08);
}

.history-item-active {
  background: rgba(255, 140, 66, 0.12);
  border: 1rpx solid var(--border-light);
}

.history-item-content {
  flex: 1;
  min-width: 0;
}

.history-item-title {
  font-size: 28rpx;
  color: var(--text-primary);
  overflow: hidden;
  white-space: nowrap;
  text-overflow: ellipsis;
  display: block;
}

.history-item-time {
  font-size: 22rpx;
  color: var(--text-light);
  margin-top: 6rpx;
  display: block;
}

.history-item-delete {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  color: var(--text-light);
  flex-shrink: 0;
  border-radius: 50%;
}

.history-item-delete:active {
  background: rgba(255, 107, 107, 0.15);
  color: var(--color-warm-coral);
}

.history-empty {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
  font-size: 28rpx;
  color: var(--text-light);
}
