/**pages/login/index.wxss - 登录页样式**/

page {
  padding: 0;
  background: linear-gradient(180deg, var(--bg-gradient-start) 0%, var(--bg-gradient-mid) 50%, var(--bg-gradient-end) 100%);
}

.page-content {
  position: relative;
  z-index: 1;
  padding: 0 var(--spacing-lg);
}

/* ========== Logo 区域 ========== */
.logo-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 0 60rpx;
}

.logo-icon {
  font-size: 120rpx;
  margin-bottom: var(--spacing-md);
}

.logo-title {
  font-size: 48rpx;
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: var(--spacing-xs);
}

.logo-desc {
  font-size: 28rpx;
  color: var(--text-secondary);
  letter-spacing: 2rpx;
}

/* ========== 微信登录按钮 ========== */
.wx-login-section {
  margin: var(--spacing-lg) 0;
}

.wx-login-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  width: 100%;
  height: 96rpx;
  background: #07C160;
  border-radius: var(--radius-full);
  border: none;
  box-shadow: 0 8rpx 24rpx rgba(7, 193, 96, 0.3);
}

.wx-login-btn::after {
  border: none;
}

.wx-login-btn:active {
  opacity: 0.85;
}

.wx-login-icon {
  font-size: 36rpx;
}

.wx-login-text {
  font-size: 32rpx;
  font-weight: 500;
  color: #FFFFFF;
}

/* ========== 分隔线 ========== */
.divider-section {
  display: flex;
  align-items: center;
  gap: var(--spacing-sm);
  margin: var(--spacing-md) 0;
}

.divider-line {
  flex: 1;
  height: 1rpx;
  background: var(--border-light);
}

.divider-text {
  font-size: 24rpx;
  color: var(--text-light);
  white-space: nowrap;
}

/* ========== Tab 切换 ========== */
.tab-bar {
  display: flex;
  gap: 0;
  margin-bottom: var(--spacing-lg);
  background: rgba(255, 140, 66, 0.06);
  border-radius: var(--radius-full);
  padding: 6rpx;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 20rpx 0;
  font-size: 28rpx;
  color: var(--text-secondary);
  border-radius: var(--radius-full);
  transition: all 0.3s ease;
}

.tab-active {
  background: var(--surface-card);
  color: var(--color-primary);
  font-weight: 600;
  box-shadow: var(--shadow-soft);
}

/* ========== 表单区域 ========== */
.form-section {
  display: flex;
  flex-direction: column;
  gap: var(--spacing-sm);
}

.input-group {
  background: var(--surface-card);
  border-radius: var(--radius-lg);
  border: 1rpx solid var(--border-light);
  padding: 0 var(--spacing-md);
  height: 96rpx;
  display: flex;
  align-items: center;
}

.form-input {
  flex: 1;
  height: 96rpx;
  font-size: 30rpx;
  color: var(--text-primary);
}

.form-placeholder {
  color: var(--text-light);
  font-size: 28rpx;
}

.code-group {
  padding-right: 8rpx;
}

.code-input {
  flex: 1;
}

.code-btn {
  flex-shrink: 0;
  padding: 16rpx 28rpx;
  font-size: 26rpx;
  color: var(--color-primary);
  background: rgba(255, 140, 66, 0.1);
  border-radius: var(--radius-full);
  border: 1rpx solid var(--border-light);
  white-space: nowrap;
}

.code-btn:active {
  opacity: 0.7;
}

.code-btn-disabled {
  color: var(--text-light);
  background: rgba(0, 0, 0, 0.04);
  border-color: transparent;
}

/* ========== 登录按钮 ========== */
.login-btn-section {
  margin-top: var(--spacing-lg);
}

.login-btn {
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  text-align: center;
  font-size: 32rpx;
  padding: 0;
}

/* ========== 用户协议 ========== */
.agreement-section {
  margin-top: var(--spacing-lg);
  padding-bottom: var(--spacing-xl);
}

.agreement-check {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
}

.check-box {
  width: 36rpx;
  height: 36rpx;
  border-radius: 8rpx;
  border: 2rpx solid var(--border-light);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  color: var(--text-on-primary);
  flex-shrink: 0;
}

.agreed .check-box {
  background: var(--color-primary);
  border-color: var(--color-primary);
}

.agreement-text {
  font-size: 24rpx;
  color: var(--text-light);
}
