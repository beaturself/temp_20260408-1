/**pages/profile/index.wxss - 个人中心样式**/

.page-content {
  position: relative;
  z-index: 1;
  height: 100%;
  padding: var(--spacing-sm) var(--spacing-md);
}

/* ========== 用户信息卡片 ========== */
.user-card {
  display: flex;
  align-items: center;
  padding: var(--spacing-lg) var(--spacing-md);
  margin: var(--spacing-sm) 0;
}

.user-avatar-wrap {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  padding: 4rpx;
  background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-warm-amber) 50%, var(--color-warm-sunset) 100%);
  flex-shrink: 0;
  margin-right: var(--spacing-md);
}

.user-avatar {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  border: 4rpx solid #fff;
}

.user-avatar-default {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  background: var(--color-warm-cream);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 56rpx;
  border: 4rpx solid #fff;
}

.user-info {
  flex: 1;
  min-width: 0;
}

.user-name {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 8rpx;
}

.user-login-type {
  margin-top: 4rpx;
}

.user-login-hint {
  font-size: 26rpx;
  color: var(--text-light);
}

.user-arrow {
  font-size: 40rpx;
  color: var(--text-light);
  flex-shrink: 0;
}

/* ========== 会员入口卡片 ========== */
.vip-entry {
  position: relative;
  margin: var(--spacing-sm) 0;
  border-radius: var(--radius-lg);
  overflow: hidden;
  box-shadow: var(--shadow-card);
}

.vip-entry-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(135deg, #3D2C22 0%, #5C3D2E 50%, #8B5E3C 100%);
}

.vip-entry-content {
  position: relative;
  z-index: 1;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx var(--spacing-md);
}

.vip-entry-left {
  display: flex;
  align-items: center;
  gap: var(--spacing-sm);
}

.vip-entry-icon {
  font-size: 48rpx;
}

.vip-entry-info {
  display: flex;
  flex-direction: column;
}

.vip-entry-title {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--color-warm-gold);
}

.vip-entry-desc {
  font-size: 22rpx;
  color: var(--color-warm-peach);
  margin-top: 4rpx;
}

.vip-entry-btn {
  background: linear-gradient(135deg, var(--color-warm-gold), var(--color-warm-amber));
  color: #3D2C22;
  font-size: 24rpx;
  font-weight: 600;
  padding: 12rpx 28rpx;
  border-radius: var(--radius-full);
}

.vip-entry:active .vip-entry-btn {
  opacity: 0.85;
}

/* ========== 功能列表 ========== */
.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-secondary);
  padding: var(--spacing-md) 0 var(--spacing-sm);
}

.menu-group {
  padding: 0;
  overflow: hidden;
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 32rpx var(--spacing-md);
}

.menu-item:active {
  background: var(--surface-overlay);
}

.menu-icon {
  width: 48rpx;
  font-size: 36rpx;
  text-align: center;
  margin-right: var(--spacing-sm);
  flex-shrink: 0;
}

.menu-text {
  flex: 1;
  font-size: 30rpx;
  font-weight: 400;
  color: var(--text-primary);
  letter-spacing: 1rpx;
}

.menu-arrow {
  font-size: 36rpx;
  color: var(--text-light);
  flex-shrink: 0;
}

.menu-divider {
  height: 1rpx;
  background: var(--border-light);
  margin-left: calc(48rpx + var(--spacing-sm) + var(--spacing-md));
}

/* ========== 退出登录 ========== */
.logout-section {
  padding: var(--spacing-xl) var(--spacing-md) 0;
}

.logout-btn {
  width: 100%;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  color: var(--color-warm-coral);
  background: var(--surface-card);
  border-radius: var(--radius-lg);
  border: 1rpx solid rgba(255, 107, 107, 0.2);
  box-shadow: var(--shadow-soft);
}

.logout-btn:active {
  background: rgba(255, 107, 107, 0.05);
}

.logout-btn::after {
  border: none;
}

/* ========== 底部留白 ========== */
.bottom-spacer {
  height: 60rpx;
}
